{
  "version": "0.1.0",
  "langrev": "1",
  "sources": [ "src/**", "vendor/getopt/src/**" ],
  "output": "build",
  "link-libc": true,
  "targets": {
    "cidoo-clock-c3": {
      "type": "executable",
      "safe": true,
      "opt": "O0",
      "linked-libraries": [
        "IOKit.framework",
        "CoreFoundation.framework"
      ]
    },
    "release": {
      "type": "executable",
      "safe": false,
      "opt": "O3",
      "strip-unused": true,
      "linked-libraries": [
        "IOKit.framework",
        "CoreFoundation.framework"
      ]
    }
  }
}
